# ========================================
# APP
# ========================================
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# ========================================
# DATABASE
# DB_CLIENT: 'sqlite3' (default, local file) or 'pg' (PostgreSQL)
# DB_FILE: only used for sqlite3. Defaults to ./storage/database.sqlite
# ========================================
DB_CLIENT="sqlite3"
# DB_FILE="./storage/database.sqlite"
DB_HOST="localhost"
DB_PORT=5432
DB_USER="postgres"
DB_PASSWORD="password"
DB_DATABASE="waha_sender"
DB_SSL="false"
DB_POOL_MIN=2
DB_POOL_MAX=10

# ========================================
# REDIS (required for BullMQ queue / worker)
# ========================================
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=""
REDIS_DB=0

# ========================================
# WORKER
# How many campaigns may dispatch in parallel (1 message per campaign at a time).
# ========================================
WORKER_CONCURRENCY=10

# ========================================
# STORAGE (uploads)
# STORAGE_TYPE: 'local' or 's3'
# ========================================
STORAGE_TYPE="local"
UPLOAD_MAX_BYTES=20971520

# AWS S3 / R2 / MinIO (only if STORAGE_TYPE=s3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
# AWS_BUCKET=""
# AWS_ENDPOINT=""

# ========================================
# AUTH
# JWT_SECRET MUST be a long random string in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Docker/K8s secrets: any var can be read from a file by adding the suffix _FROM_FILE,
#   e.g. JWT_SECRET_FROM_FILE=/run/secrets/jwt_secret
# ========================================
JWT_SECRET="change-me-please-change-me-please-change-me"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="waha_session"
COOKIE_SECURE="false"
# When behind a reverse proxy (nginx, traefik, cloudflare): 'loopback' (default), 'true', or a number of hops
TRUST_PROXY="loopback"

# Password policy (applied on register/change-password)
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_COMPLEXITY="true"

# ========================================
# WAHA WEBHOOK
# Shared secret sent in the X-Webhook-Secret header.
# When WAHA_WEBHOOK_HMAC=true, the secret is used as HMAC-SHA256 key and the
# header X-Webhook-Hmac-SHA256 (or X-Hub-Signature-256: sha256=...) is verified.
# ========================================
# WAHA_WEBHOOK_SECRET=""
WAHA_WEBHOOK_HMAC="false"

# ========================================
# CIRCUIT BREAKER (per user+session, anti-ban)
# ========================================
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_MS=300000
CIRCUIT_BREAKER_COOLDOWN_MS=900000

# ========================================
# OBSERVABILITY
# ========================================
LOG_LEVEL="debug"
LOG_TO_FILE="true"
LOG_DIR="storage/logs"
METRICS_ENABLED="true"
BULL_BOARD_ENABLED="true"

# ========================================
# SaaS — SELF-SERVICE & E-MAIL
# APP_PUBLIC_URL builds links in transactional e-mails / checkout returns.
# ENABLE_SIGNUP toggles open registration (bootstrap admin always allowed).
# REQUIRE_EMAIL_VERIFICATION gates sending until the e-mail is confirmed.
# ========================================
APP_PUBLIC_URL="http://localhost:3000"
ENABLE_SIGNUP="true"
REQUIRE_EMAIL_VERIFICATION="false"

# Transactional e-mail (SMTP). Leave MAIL_HOST empty to log e-mails to the
# console instead of sending (useful for local development).
# MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_SECURE="false"
# MAIL_USER=""
# MAIL_PASSWORD=""
MAIL_FROM="WahaSender <no-reply@wahasender.local>"

# ========================================
# SaaS — BILLING (Mercado Pago)
# Without MP_ACCESS_TOKEN the billing runs in MOCK mode (checkout activates the
# plan locally) so the full flow is testable without credentials.
# Use TEST credentials for sandbox: https://www.mercadopago.com.br/developers
# ========================================
# MP_ACCESS_TOKEN=""
# MP_PUBLIC_KEY=""
# MP_WEBHOOK_SECRET=""

# ========================================
# OPTIONAL INTEGRATIONS
# ========================================
# GEMINI_API_KEY=""
